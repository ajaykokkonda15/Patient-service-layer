# ─────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────
# MongoDB connection
# ─────────────────────────────────────────────────
DB_USER=your_mongo_username
DB_PASSWORD=your_mongo_password

# For MongoDB Atlas — use just the hostname, no scheme, no port:
#   DB_SERVER=cluster0.xxxxx.mongodb.net
# For self-hosted — include the port:
#   DB_SERVER=localhost:27017
DB_SERVER=cluster0.xxxxx.mongodb.net

DB_NAME=patient_db
